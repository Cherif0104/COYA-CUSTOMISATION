<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_coya_create_contact_from_collecte_wizard_form" model="ir.ui.view">
            <field name="name">coya.create.contact.from.collecte.wizard.form</field>
            <field name="model">coya.create.contact.from.collecte.wizard</field>
            <field name="arch" type="xml">
                <form string="Créer un contact (via collecte)">
                    <group>
                        <field name="fiche_type_id" options="{'no_create': False, 'no_create_edit': False}"/>
                    </group>
                    <group string="Contexte">
                        <field name="programme_id" options="{'no_create': False, 'no_create_edit': False}"/>
                        <field name="projet_id" options="{'no_create': False, 'no_create_edit': False}"/>
                        <field name="bootcamp_id" options="{'no_create': False, 'no_create_edit': False}"/>
                        <field name="cohorte_id" options="{'no_create': False, 'no_create_edit': False}"/>
                    </group>
                    <footer>
                        <button string="Créer" type="object" name="action_create_contact" class="btn-primary"/>
                        <button string="Annuler" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_coya_create_contact_from_collecte_wizard" model="ir.actions.act_window">
            <field name="name">Créer un contact (via collecte)</field>
            <field name="res_model">coya.create.contact.from.collecte.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>

