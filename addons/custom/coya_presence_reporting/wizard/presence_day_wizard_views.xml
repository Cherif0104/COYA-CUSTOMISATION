<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_coya_presence_day_wizard_form" model="ir.ui.view">
        <field name="name">coya.presence.day.wizard.form</field>
        <field name="model">coya.presence.day.wizard</field>
        <field name="arch" type="xml">
            <form string="Présences — Par date">
                <group>
                    <field name="date" help="Choisissez une date pour afficher uniquement les présences de cette journée."/>
                </group>
                <footer>
                    <button name="action_open_day_view" string="Ouvrir la vue" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
